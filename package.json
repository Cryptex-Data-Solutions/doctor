{
  "name": "@estruyf/doctor",
  "version": "2.0.0",
  "description": "Maintain your documentation on SharePoint without pain.",
  "main": "dist/main.js",
  "homepage": "https://github.com/estruyf/doctor",
  "bin": {
    "doctor": "bin/doctor",
    "doctor_auto": "bin/autocomplete",
    "localm365": "bin/localm365"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "npm run build",
    "build": "npm run clean && echo \"node_modules/.bin contents:\" && ls node_modules/.bin/tsc* || echo \"tsc not found in node_modules/.bin\" && echo \"TypeScript package:\" && node -e \"try{console.log(require('typescript/package.json').version)}catch(e){console.log('not installed')}\" && ./node_modules/.bin/tsc",
    "watch": "node ./scripts/reset-debug.js && npx -p typescript tsc -w",
    "watch:debug": "node ./scripts/init-debug.js && npx -p typescript tsc -w",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run --config e2e/vitest.config.ts",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "docs": "cd docs && hogo serve",
    "prepare": "(husky || true) && npm run build"
  },
  "keywords": [
    "cli",
    "markdown",
    "documentation"
  ],
  "author": "Elio Struyf",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/estruyf/doctor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/estruyf/doctor.git"
  },
  "maintainers": [
    {
      "name": "Elio Struyf",
      "email": "elio@struyfconsulting.be",
      "url": "https://www.eliostruyf.com"
    }
  ],
  "contributors": [
    {
      "name": "Elio Struyf",
      "email": "elio@struyfconsulting.be",
      "url": "https://www.eliostruyf.com"
    }
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/estruyf"
    },
    {
      "type": "buymeacoffee",
      "url": "https://www.buymeacoffee.com/zMeFRy9"
    }
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/cheerio": "0.22.24",
    "@types/clean-css": "4.2.3",
    "@types/cross-spawn": "6.0.2",
    "@types/inquirer": "7.3.1",
    "@types/listr": "0.14.2",
    "@types/markdown-it": "12.0.1",
    "@types/mime": "2.0.3",
    "@types/omelette": "0.4.1",
    "husky": "^9.0.0",
    "tslib": "2.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@fluentui/svg-icons": "1.1.101",
    "@pnp/cli-microsoft365": "^11.4.0",
    "applicationinsights": "^2.9.0",
    "arg": "4.1.3",
    "cheerio": "^1.0.0",
    "clean-css": "5.1.0",
    "cross-spawn": "7.0.3",
    "fast-glob": "3.2.5",
    "gray-matter": "4.0.2",
    "highlight.js": "^11.9.0",
    "html-entities": "2.1.0",
    "inquirer": "^8.0.0",
    "kleur": "4.1.4",
    "listr": "0.14.3",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "7.0.2",
    "markdown-it-shortcode-tag": "1.1.0",
    "markdown-it-table-of-contents": "0.5.2",
    "mime": "2.5.2",
    "omelette": "0.4.15",
    "rxjs": "^7.8.0",
    "typescript": "~5.5.0",
    "uuid": "^9.0.0"
  }
}
