{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "forceConsistentCasingInFileNames": true,
    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "inlineSources": false,
    "strictNullChecks": false,
    "noUnusedLocals": true,
    "lib": [
      "DOM",
      "ES2015"
    ],
    "paths": {
      "@commands": [
        "src/commands/index.ts"
      ],
      "@helpers": [
        "src/helpers/index.ts"
      ],
      "@models": [
        "src/models/index.ts"
      ],
      "@utils": [
        "src/utils/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}